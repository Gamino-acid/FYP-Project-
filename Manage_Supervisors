    <script>
        const searchInput = document.getElementById('searchInput');
        const statusFilter = document.getElementById('statusFilter');
        const capacityFilter = document.getElementById('capacityFilter');
        const sortFilter = document.getElementById('sortFilter');
        const addSupervisorBtn = document.getElementById('addSupervisorBtn');
        const supervisorsGrid = document.getElementById('supervisorsGrid');
        
        function closeModal(modalId) {
            document.getElementById(modalId).style.display = 'none';
        }
        
        window.onclick = function(event) {
            const modals = document.querySelectorAll('.modal');
            modals.forEach(modal => {
                if (event.target == modal) {
                    modal.style.display = 'none';
                }
            });
        }

        function openProfileModal(card) {
            const name = card.getAttribute('data-name');
            const id = card.getAttribute('data-supervisor-id');
            const title = card.getAttribute('data-title');
            const email = card.getAttribute('data-email');
            const phone = card.getAttribute('data-phone');
            const room = card.getAttribute('data-room');
            const spec = card.getAttribute('data-specialization');
            const interest = card.getAttribute('data-interest');
            const capacity = card.getAttribute('data-capacity');
            const current = card.getAttribute('data-current-students');
            const status = card.getAttribute('data-status');
            
            const modalBody = document.getElementById('profileModalBody');
            
            modalBody.innerHTML = `
                <div class="profile-detail">
                    <p><strong>Name:</strong> ${name}</p>
                    <p><strong>Staff ID:</strong> ${id}</p>
                    <p><strong>Position:</strong> ${title}</p>
                    <p><strong>Status:</strong> <span class="status-badge ${status === 'Active' ? 'active' : 'on-leave'}">${status}</span></p>
                </div>
                <hr style="margin: 1rem 0; border: 0; border-top: 1px solid #eee;">
                <div class="profile-detail">
                    <p><strong>Email:</strong> ${email}</p>
                    <p><strong>Phone:</strong> ${phone}</p>
                    <p><strong>Office:</strong> ${room}</p>
                </div>
                <hr style="margin: 1rem 0; border: 0; border-top: 1px solid #eee;">
                <div class="profile-detail">
                    <p><strong>Area of Interest:</strong> ${interest}</p>
                    <p><strong>Capacity:</strong> ${current} / ${capacity} students</p>
                </div>
            `;
            
            document.getElementById('profileModal').style.display = 'flex';
        }

        function openAssignModal(card) {
            const name = card.getAttribute('data-name');
            const id = card.getAttribute('data-supervisor-id');

            document.getElementById('assignSupervisorName').textContent = name;
            document.getElementById('assignSupervisorId').value = id;

            document.getElementById('assignModal').style.display = 'flex';
        }

        document.getElementById('assignStudentForm').addEventListener('submit', function(e) {
            e.preventDefault();
            
            const supervisorId = document.getElementById('assignSupervisorId').value;
            const studentId = document.getElementById('studentSelect').value;
            const projectTitle = document.getElementById('projectTitle').value;
            
            if (!studentId) {
                alert("Please select a student.");
                return;
            }
            
            console.log(`Submitting assignment for Supervisor ID: ${supervisorId}, Student ID: ${studentId}, Project: ${projectTitle}`);
            
            alert(`SUCCESS: Student ${studentId} assigned to Supervisor ${supervisorId} for project: ${projectTitle}. (In a real system, this updates the DB.)`);
            closeModal('assignModal');
            this.reset();
        });

        function handleSupervisorActions(event) {
            const button = event.target;
            const card = button.closest('.supervisor-card'); 

            if (!card || !button.classList.contains('btn')) return;

            if (button.classList.contains('view-profile-btn')) {
                openProfileModal(card);
            } else if (button.classList.contains('assign-student-btn') && !button.disabled) {
                openAssignModal(card);
            }
        }

        supervisorsGrid.addEventListener('click', handleSupervisorActions);

        const getSupervisorCards = () => document.querySelectorAll('.supervisor-card');

        searchInput.addEventListener('input', function() {
            const searchTerm = this.value.toLowerCase();
            
            getSupervisorCards().forEach(card => {
                const name = card.querySelector('.supervisor-info h3').textContent.toLowerCase();
                const staffId = card.querySelector('.staff-id').textContent.toLowerCase();
                
                card.style.display = (name.includes(searchTerm) || staffId.includes(searchTerm)) ? 'grid' : 'none';
            });
        });

        statusFilter.addEventListener('change', function() {
            const selectedStatus = this.value;
            
            getSupervisorCards().forEach(card => {
                const statusBadge = card.querySelector('.status-badge');
                
                if (selectedStatus === '') {
                    card.style.display = 'grid';
                } else {
                    const hasStatus = statusBadge.classList.contains(selectedStatus);
                    card.style.display = hasStatus ? 'grid' : 'none';
                }
            });
        });

        capacityFilter.addEventListener('change', function() {
            const selectedCapacity = this.value;
            
            getSupervisorCards().forEach(card => {
                const capacityText = card.querySelector('.capacity-label').textContent;
                const match = capacityText.match(/(\d+)\/(\d+)/);
                
                if (match) {
                    const current = parseInt(match[1]);
                    const max = parseInt(match[2]);
                    const isFull = current >= max;
                    
                    if (selectedCapacity === '') {
                        card.style.display = 'grid';
                    } else if (selectedCapacity === 'available' && !isFull) {
                        card.style.display = 'grid';
                    } else if (selectedCapacity === 'full' && isFull) {
                        card.style.display = 'grid';
                    } else {
                        card.style.display = 'none';
                    }
                }
            });
        });

        sortFilter.addEventListener('change', function() {
            const sortBy = this.value;
            const grid = document.getElementById('supervisorsGrid');
            const cardsArray = Array.from(getSupervisorCards());
            
            if (sortBy === 'name') {
                cardsArray.sort((a, b) => {
                    const nameA = a.querySelector('.supervisor-info h3').textContent;
                    const nameB = b.querySelector('.supervisor-info h3').textContent;
                    return nameA.localeCompare(nameB);
                });
            } else if (sortBy === 'students') {
                cardsArray.sort((a, b) => {
                    const studentsA = parseInt(a.querySelector('.stat-item:nth-child(1) .stat-number').textContent);
                    const studentsB = parseInt(b.querySelector('.stat-item:nth-child(1) .stat-number').textContent);
                    return studentsB - studentsA; 
                });
            } else if (sortBy === 'workload') {
                cardsArray.sort((a, b) => {
                    const capacityA = a.querySelector('.capacity-label').textContent.match(/(\d+)\/(\d+)/);
                    const capacityB = b.querySelector('.capacity-label').textContent.match(/(\d+)\/(\d+)/);
                    
                    if (!capacityA || !capacityB) return 0;

                    const percentA = (parseInt(capacityA[1]) / parseInt(capacityA[2]));
                    const percentB = (parseInt(capacityB[1]) / parseInt(capacityB[2]));
                    return percentB - percentA; 
                });
            }
            
            if (sortBy !== '') {
                cardsArray.forEach(card => grid.appendChild(card));
            }
        });
        
