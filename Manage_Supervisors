                formData.append('fyp_supervisorid', staffId);
                formData.append('fyp_roomno', roomNo);
                formData.append('fyp_email', email);
                formData.append('fyp_contactno', phone);
                formData.append('fyp_specialization', 'NA'); 
                formData.append('fyp_areaofinterest', specializations);
                formData.append('fyp_profiling', capacity);


fetch('add_supervisor_submit.php', {
    method: 'POST',
    body: formData
})
